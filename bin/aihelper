#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export AIHELPER_TARGET_ROOT="${AIHELPER_TARGET_ROOT:-$PWD}"

print_guide() {
  cat <<'EOF'
aihelper - portable AI helper for projects that keep knowledge in ai/

Usage:
  aihelper "<prompt>"
  aihelper analyze "<prompt>"
  aihelper analyze --format prompt "<prompt>"
  aihelper feedback "<prompt>" --intent "<intent>" [--features ...] [--accepted] [--rating N] [--notes "..."]
  aihelper feedback-summary
  aihelper rebuild-index
  aihelper cache build|status|clean|warm
  aihelper cache watch [--once]
  aihelper cache watch-all --extra-project <extra-project-path>
  aihelper prompt-blocks build|show
  aihelper diff-summary
  aihelper memory add|recall
  aihelper symbol find|context "<symbol>"
  aihelper deps "<symbol-or-file>"
  aihelper route "<task>"
  aihelper patch-plan "<task>" --file path/to/file
  aihelper patch-apply --patch-file /tmp/change.patch [--apply]
  aihelper validate-files path/to/file.php
  aihelper ollama health
  aihelper ollama prewarm [--model-type tiny|medium|large]
  aihelper daemon start|stop|status
  aihelper doctor
  aihelper editor-context
  aihelper lsp definition|references|symbols <file>
  aihelper confidence [--patch-file <file>] [--files <file1> ...]
  aihelper warmup
  aihelper structural-diff [--patch-file <file>]
  aihelper hierarchical-context [--focus-file <file>] [--level 1|2|3]
  aihelper scheduler snapshot|predict|record
  aihelper capability-route "<input>" [--file-path path/to/file]
  aihelper diagnostics <file>...
  aihelper impact-graph <symbol>
  aihelper classify-op --patch-file <file>
  aihelper degradation

Examples:
  aihelper "trace upload flow"
  aihelper analyze "trace upload flow"
  aihelper analyze --format prompt "trace upload flow"
  aihelper feedback "trace upload flow" --intent upload_flow --features ingestion tracing
  aihelper feedback-summary
  aihelper rebuild-index
  aihelper cache build
  aihelper cache warm
  aihelper cache watch --once
  aihelper cache watch-all --once --extra-project <extra-project-path>
  aihelper prompt-blocks build
  aihelper diff-summary
  aihelper symbol find analyze_request
  aihelper route "fix checkout service"
  aihelper capability-route "Error: TypeError at UserService.getUser()"
  aihelper ollama health
  aihelper ollama prewarm --model-type medium

Notes:
  - If no command is given, this guide is shown.
  - Commands accept --project-root when you want to target another repository.
  - AIHELPER_TARGET_ROOT defaults to the current working directory.
  - Output is Markdown by default; pass --format json to get JSON or --format prompt to get the rewritten prompt.
  - You can pipe a prompt on stdin for multiline input.
EOF
}

run_analyze() {
  local -a forwarded=()
  local -a prompt_parts=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-root|--format|--max-context-chars)
        if [[ $# -lt 2 ]]; then
          echo "Missing value for $1" >&2
          exit 1
        fi
        forwarded+=("$1" "$2")
        shift 2
        ;;
      --auto-update-kb|--json|-json)
        forwarded+=("$1")
        shift
        ;;
      -h|--help|help)
        forwarded+=("$1")
        shift
        ;;
      --)
        shift
        if [[ $# -gt 0 ]]; then
          prompt_parts+=("$@")
        fi
        break
        ;;
      *)
        prompt_parts+=("$1")
        shift
        ;;
    esac
  done

  if [[ ${#prompt_parts[@]} -gt 0 ]]; then
    local prompt
    prompt="$(printf '%s ' "${prompt_parts[@]}")"
    prompt="${prompt% }"
    forwarded+=("$prompt")
  fi

  exec python3 "$SCRIPT_DIR/../context_engine/main.py" analyze "${forwarded[@]}"
}

if [[ $# -eq 0 ]]; then
  if ! [[ -t 0 ]]; then
    stdin_prompt="$(cat)"
    if [[ -n "${stdin_prompt//[[:space:]]/}" ]]; then
      exec python3 "$SCRIPT_DIR/../context_engine/main.py" analyze "$stdin_prompt"
    fi
  fi
  print_guide
  exit 0
fi

case "$1" in
  -h|--help|help)
    print_guide
    exit 0
    ;;
  analyze|feedback|feedback-summary|feedback_summary|rebuild-index|rebuild_index|cache|prompt-blocks|prompt_blocks|diff-summary|diff_summary|memory|symbol|deps|route|patch-plan|patch_plan|patch-apply|patch_apply|validate-files|validate_files|ollama|daemon|doctor|editor-context|editor_context|lsp|confidence|structural-diff|structural_diff|hierarchical-context|hierarchical_context|scheduler|intent-route|intent_route|capability-route|capability_route|telemetry|health|diagnostics|impact-graph|impact_graph|classify-op|classify_op|degradation|warmup)
    case "$1" in
      rebuild_index) set -- rebuild-index "${@:2}" ;;
      feedback_summary) set -- feedback-summary "${@:2}" ;;
      patch_plan) set -- patch-plan "${@:2}" ;;
      patch_apply) set -- patch-apply "${@:2}" ;;
      validate_files) set -- validate-files "${@:2}" ;;
      prompt_blocks) set -- prompt-blocks "${@:2}" ;;
      diff_summary) set -- diff-summary "${@:2}" ;;
      capability_route) set -- capability-route "${@:2}" ;;
    esac
    if [[ "$1" == "analyze" ]]; then
      shift
      run_analyze "$@"
    fi
    exec python3 "$SCRIPT_DIR/../context_engine/main.py" "$@"
    ;;
  *)
    run_analyze "$@"
    ;;
esac
