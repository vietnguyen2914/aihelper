#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export AIHELPER_TARGET_ROOT="${AIHELPER_TARGET_ROOT:-$PWD}"

print_guide() {
  cat <<'EOF'
aihelper - portable AI helper for projects that keep knowledge in ai/

Usage:
  aihelper "<prompt>"
  aihelper analyze "<prompt>"
  aihelper analyze "<prompt>" --json
  aihelper feedback "<prompt>" --intent "<intent>" [--features ...] [--accepted] [--rating N] [--notes "..."]
  aihelper feedback-summary
  aihelper rebuild-index

Examples:
  aihelper "trace upload flow"
  aihelper analyze "trace upload flow"
  aihelper analyze "trace upload flow" --json
  aihelper feedback "trace upload flow" --intent upload_flow --features ingestion tracing
  aihelper feedback-summary
  aihelper rebuild-index

Notes:
  - If no command is given, this guide is shown.
  - Commands accept --project-root when you want to target another repository.
  - AIHELPER_TARGET_ROOT defaults to the current working directory.
  - Output is Markdown by default; pass --json or -json to get JSON.
  - You can pipe a prompt on stdin for multiline input.
EOF
}

if [[ $# -eq 0 ]]; then
  if ! [[ -t 0 ]]; then
    stdin_prompt="$(cat)"
    if [[ -n "${stdin_prompt//[[:space:]]/}" ]]; then
      exec python3 "$SCRIPT_DIR/../context_engine/main.py" analyze "$stdin_prompt"
    fi
  fi
  print_guide
  exit 0
fi

case "$1" in
  -h|--help|help)
    print_guide
    exit 0
    ;;
  analyze|feedback|feedback-summary|feedback_summary|rebuild-index|rebuild_index)
    case "$1" in
      rebuild_index) set -- rebuild-index "${@:2}" ;;
      feedback_summary) set -- feedback-summary "${@:2}" ;;
    esac
    exec python3 "$SCRIPT_DIR/../context_engine/main.py" "$@"
    ;;
  *)
    if [[ "$1" == -* || ( $# -eq 1 && "$1" =~ [[:space:]] ) ]]; then
      exec python3 "$SCRIPT_DIR/../context_engine/main.py" analyze "$@"
    fi
    echo "Unknown command: $1" >&2
    echo >&2
    print_guide >&2
    exit 1
    ;;
esac
